<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Recover Instagram Akkaunt</title>
<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f0f2f5;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}
.box {
    background: #fff;
    width: 320px;
    padding: 25px;
    border-radius: 10px;
    box-shadow: 0 5px 20px rgba(0,0,0,.2);
    text-align: center;
}
h2 {
    margin-bottom: 10px;
}
.info {
    font-size: 12px;
    color: #666;
    margin-bottom: 15px;
}
input {
    width: 90%;
    padding: 10px;
    margin: 8px 0;
    border: 1px solid #ccc;
    border-radius: 5px;
}
button {
    width: 95%;
    padding: 10px;
    background: #1877f2;
    color: #fff;
    border: none;
    border-radius: 5px;
    font-size: 15px;
}
a {
    display: block;
    margin-top: 12px;
    font-size: 13px;
    color: #1877f2;
    text-decoration: none;
}
#msg {
    margin-top: 10px;
    font-size: 13px;
    color: red;
}
.hidden {
    display: none;
}
</style>
</head>
<body>

<div class="box">

    <!-- LOGIN -->
    <div id="loginBox">
        <h2>Recover Instagram Akkaunt</h2>
        <div class="info">Demo loyiha — o‘rganish uchun</div>

        <input type="text" id="loginUser" placeholder="Username yoki Email">
        <input type="password" id="loginPass" placeholder="Parol">
        <button onclick="login()">Kirish</button>

        <a href="#" onclick="showForgot()">Parolni unutdingizmi?</a>
        <p id="msg"></p>
    </div>

    <!-- FORGOT -->
    <div id="forgotBox" class="hidden">
        <h2>Parolni tiklash</h2>
        <div class="info">Email yoki telefon raqam kiriting</div>

        <input type="text" id="contact" placeholder="Email yoki telefon">
        <button onclick="sendCode()">Kod yuborish</button>

        <a href="#" onclick="backLogin()">Ortga qaytish</a>
    </div>

    <!-- RESET -->
    <div id="resetBox" class="hidden">
        <h2>Kodni tasdiqlash</h2>

        <input type="text" id="code" placeholder="Tasdiqlash kodi">
        <input type="password" id="newpass" placeholder="Yangi parol">
        <button onclick="resetPass()">Parolni yangilash</button>
    </div>

</div>

<script>
function login() {
    let u = loginUser.value;
    let p = loginPass.value;

    if(u === "demo" && p === "1234") {
        alert("Akkaunt topildi (DEMO)");
        msg.innerHTML = "";
    } else {
        msg.innerHTML = "Username yoki parol noto‘g‘ri";
    }
}

function showForgot() {
    loginBox.classList.add("hidden");
    forgotBox.classList.remove("hidden");
}

function backLogin() {
    forgotBox.classList.add("hidden");
    loginBox.classList.remove("hidden");
}

function sendCode() {
    if(contact.value === "") {
        alert("Ma’lumot kiriting");
    } else {
        alert("Tasdiqlash kodi yuborildi (DEMO)");
        forgotBox.classList.add("hidden");
        resetBox.classList.remove("hidden");
    }
}

function resetPass() {
    if(code.value && newpass.value) {
        alert("Parol yangilandi (DEMO)");
        location.reload();
    } else {
        alert("Hammasini to‘ldiring");
    }
}
</script>

</body>
</html>